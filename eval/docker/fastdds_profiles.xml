<?xml version="1.0" encoding="UTF-8"?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <!-- Define a UDPv4 transport named "udp_transport" -->
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>udp_transport</transport_id>
            <type>UDPv4</type>
        </transport_descriptor>
    </transport_descriptors>

    <!-- Participant profile forcing UDP and disabling SHM -->
    <participant profile_name="udp_participant_profile" is_default_profile="true">
        <rtps>
            <useBuiltinTransports>false</useBuiltinTransports>
            <userTransports>
                <transport_id>udp_transport</transport_id>
            </userTransports>
        </rtps>
    </participant>

    <!-- Default DataWriter profile: limit writer pool to 200 samples.
         Enforces the embedded-grade max_samples limit that rclpy's
         depth=200 with KEEP_ALL does NOT propagate to FastDDS.
         resourceLimitsQos is a child of <topic> (not <qos>) in
         FastDDS 2.14.6's XML schema — without this cap the default
         of 5000 makes the writer pool effectively unbounded. -->
    <data_writer profile_name="writer_profile" is_default_profile="true">
        <topic>
            <historyQos>
                <kind>KEEP_ALL</kind>
                <depth>200</depth>
            </historyQos>
            <resourceLimitsQos>
                <max_samples>200</max_samples>
                <max_instances>1</max_instances>
                <max_samples_per_instance>200</max_samples_per_instance>
                <allocated_samples>200</allocated_samples>
            </resourceLimitsQos>
        </topic>
    </data_writer>

</profiles>
